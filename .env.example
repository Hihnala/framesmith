# Framesmith — API Keys
# Copy this file to video-projects/.env and fill in your keys.
# Never commit the actual .env file.

# ElevenLabs — transcription (Scribe) and TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# NVIDIA Eye Contact NIM — eye contact correction (step 3.5)
NVIDIA_API_KEY=nvapi-your_key_here
NVIDIA_EYE_CONTACT_FUNCTION_ID=7d09dd81-81ea-42ce-9909-843bdc07ec8d
# Find the function ID at: https://build.nvidia.com/nvidia/eyecontact/api
